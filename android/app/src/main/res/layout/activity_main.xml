<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bluetooth Priority Manager"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disables your Bluetooth when near a priority device"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="24dp" />

        <!-- Add Device Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Priority Device"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/deviceAddressInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Device Address (e.g., 00:1A:7D:DA:71:13)"
            android:inputType="text"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/rssiThresholdInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="RSSI Threshold (dBm, e.g., -70)"
            android:inputType="numberSigned"
            android:text="-70"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/priorityInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Priority Level (1-10)"
            android:inputType="number"
            android:text="5"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/addDeviceButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Device"
            android:layout_marginBottom="24dp" />

        <!-- Device List -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Priority Devices"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <ListView
            android:id="@+id/deviceList"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginBottom="24dp" />

        <!-- Service Controls -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Service Controls"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/startServiceButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start Monitor"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/stopServiceButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stop Monitor" />
        </LinearLayout>

        <Button
            android:id="@+id/refreshStatusButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Refresh Status"
            android:layout_marginBottom="16dp" />

        <!-- Status -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Not monitoring"
            android:textSize="14sp"
            android:background="#F0F0F0"
            android:padding="12dp" />

    </LinearLayout>
</ScrollView>
